{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Watchtower scan overview. Wire to the Prometheus datasource scraping your watchtower /v1/metrics endpoint.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Watchtower docs",
      "url": "https://openserbia.github.io/watchtower/",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Total scans",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_scans_total{job=\"$job\", instance=\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}
      }
    },
    {
      "type": "stat",
      "title": "Skipped scans",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_scans_skipped{job=\"$job\", instance=\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}]}}
      }
    },
    {
      "type": "stat",
      "title": "Containers scanned last poll",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_scanned{job=\"$job\", instance=\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "type": "stat",
      "title": "Containers failed last poll",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_failed{job=\"$job\", instance=\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}
      }
    },
    {
      "type": "timeseries",
      "title": "Scan rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "rate(watchtower_scans_total{job=\"$job\", instance=\"$instance\"}[$__rate_interval])", "legendFormat": "scans/s", "refId": "A"},
        {"expr": "rate(watchtower_scans_skipped{job=\"$job\", instance=\"$instance\"}[$__rate_interval])", "legendFormat": "skipped/s", "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 10}}
      }
    },
    {
      "type": "timeseries",
      "title": "Containers per poll",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_scanned{job=\"$job\", instance=\"$instance\"}", "legendFormat": "scanned", "refId": "A"},
        {"expr": "watchtower_containers_updated{job=\"$job\", instance=\"$instance\"}", "legendFormat": "updated", "refId": "B"},
        {"expr": "watchtower_containers_failed{job=\"$job\", instance=\"$instance\"}", "legendFormat": "failed", "refId": "C"}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"lineInterpolation": "stepAfter", "lineWidth": 1, "fillOpacity": 10}}
      }
    },
    {
      "type": "piechart",
      "title": "Watch status (managed / excluded / unmanaged)",
      "description": "Current classification from the last audit pass. `unmanaged` = no com.centurylinklabs.watchtower.enable label. Pair with /v1/audit for per-container detail.",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_managed{job=\"$job\", instance=\"$instance\"}", "legendFormat": "managed", "refId": "A"},
        {"expr": "watchtower_containers_excluded{job=\"$job\", instance=\"$instance\"}", "legendFormat": "excluded", "refId": "B"},
        {"expr": "watchtower_containers_unmanaged{job=\"$job\", instance=\"$instance\"}", "legendFormat": "unmanaged", "refId": "C"}
      ],
      "options": {
        "pieType": "donut",
        "legend": {"displayMode": "table", "placement": "right", "values": ["value"]},
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "unmanaged"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "excluded"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "gray"}}]},
          {"matcher": {"id": "byName", "options": "managed"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      }
    },
    {
      "type": "stat",
      "title": "Unmanaged containers (silently skipped)",
      "description": "Count of containers with no com.centurylinklabs.watchtower.enable label. Under --label-enable these are invisible to Watchtower. Non-zero values suggest an operator forgot to label something — check /v1/audit for names or enable --audit-unmanaged for log warnings.",
      "gridPos": {"h": 8, "w": 4, "x": 8, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_unmanaged{job=\"$job\", instance=\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "area"}
    },
    {
      "type": "timeseries",
      "title": "Watch-status history",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_managed{job=\"$job\", instance=\"$instance\"}", "legendFormat": "managed", "refId": "A"},
        {"expr": "watchtower_containers_excluded{job=\"$job\", instance=\"$instance\"}", "legendFormat": "excluded", "refId": "B"},
        {"expr": "watchtower_containers_unmanaged{job=\"$job\", instance=\"$instance\"}", "legendFormat": "unmanaged", "refId": "C"}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"lineInterpolation": "stepAfter", "lineWidth": 1, "fillOpacity": 10, "stacking": {"mode": "normal"}}}
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["watchtower", "docker", "openserbia"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0
      },
      {
        "name": "job",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(watchtower_scans_total, job)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "sort": 1,
        "current": {"text": "watchtower", "value": "watchtower"}
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(watchtower_scans_total{job=\"$job\"}, instance)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Watchtower",
  "uid": "watchtower-openserbia",
  "version": 1,
  "weekStart": ""
}
