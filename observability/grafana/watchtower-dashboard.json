{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "enable": true,
        "name": "Rollback",
        "iconColor": "red",
        "expr": "changes(watchtower_rollbacks_total{job=\"$job\", instance=~\"$instance\"}[1m]) > 0",
        "titleFormat": "Rollback triggered",
        "textFormat": "Watchtower reverted a container after health-check failure (watchtower_rollbacks_total)",
        "step": "60s"
      },
      {
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "enable": true,
        "name": "Watchtower restart",
        "iconColor": "blue",
        "expr": "resets(watchtower_scans_total{job=\"$job\", instance=~\"$instance\"}[5m]) > 0",
        "titleFormat": "Watchtower process restarted",
        "textFormat": "watchtower_scans_total reset detected — likely a daemon restart or redeploy",
        "step": "60s"
      },
      {
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "enable": true,
        "name": "Unmanaged container appeared",
        "iconColor": "orange",
        "expr": "delta(watchtower_containers_unmanaged{job=\"$job\", instance=~\"$instance\"}[5m]) > 0",
        "titleFormat": "New unmanaged container",
        "textFormat": "A container without the com.centurylinklabs.watchtower.enable label appeared — hit /v1/audit for the name",
        "step": "60s"
      }
    ]
  },
  "description": "Watchtower scan overview. Wire to the Prometheus datasource scraping your watchtower /v1/metrics endpoint.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Watchtower docs",
      "url": "https://openserbia.github.io/watchtower/",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Total scans",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_scans_total{job=\"$job\", instance=~\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}
      }
    },
    {
      "type": "stat",
      "title": "Skipped scans",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_scans_skipped{job=\"$job\", instance=~\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}]}}
      }
    },
    {
      "type": "stat",
      "title": "Containers scanned last poll",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_scanned{job=\"$job\", instance=~\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "type": "stat",
      "title": "Containers failed last poll",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_failed{job=\"$job\", instance=~\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}
      }
    },
    {
      "type": "timeseries",
      "title": "Scan rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "rate(watchtower_scans_total{job=\"$job\", instance=~\"$instance\"}[$__rate_interval])", "legendFormat": "scans/s", "refId": "A"},
        {"expr": "rate(watchtower_scans_skipped{job=\"$job\", instance=~\"$instance\"}[$__rate_interval])", "legendFormat": "skipped/s", "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 10}}
      }
    },
    {
      "type": "timeseries",
      "title": "Containers per poll",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_scanned{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "scanned", "refId": "A"},
        {"expr": "watchtower_containers_updated{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "updated", "refId": "B"},
        {"expr": "watchtower_containers_failed{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "failed", "refId": "C"}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"lineInterpolation": "stepAfter", "lineWidth": 1, "fillOpacity": 10}}
      }
    },
    {
      "type": "piechart",
      "title": "Watch status",
      "description": "Current classification from the last audit pass. `unmanaged` = no com.centurylinklabs.watchtower.enable label. `infrastructure` = Docker-managed scaffolding (buildkit, Docker Desktop). Pair with /v1/audit for per-container detail.",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_managed{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "managed", "refId": "A"},
        {"expr": "watchtower_containers_excluded{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "excluded", "refId": "B"},
        {"expr": "watchtower_containers_unmanaged{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "unmanaged", "refId": "C"},
        {"expr": "watchtower_containers_infrastructure{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "infrastructure", "refId": "D"}
      ],
      "options": {
        "pieType": "donut",
        "legend": {"displayMode": "table", "placement": "right", "values": ["value"]},
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "unmanaged"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "excluded"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "gray"}}]},
          {"matcher": {"id": "byName", "options": "managed"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "infrastructure"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]}
        ]
      }
    },
    {
      "type": "stat",
      "title": "Unmanaged containers (silently skipped)",
      "description": "Count of containers with no com.centurylinklabs.watchtower.enable label. Under --label-enable these are invisible to Watchtower. Non-zero values suggest an operator forgot to label something — check /v1/audit for names or enable --audit-unmanaged for log warnings.",
      "gridPos": {"h": 8, "w": 4, "x": 8, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_unmanaged{job=\"$job\", instance=~\"$instance\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "area"}
    },
    {
      "type": "timeseries",
      "title": "Watch-status history",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "watchtower_containers_managed{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "managed", "refId": "A"},
        {"expr": "watchtower_containers_excluded{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "excluded", "refId": "B"},
        {"expr": "watchtower_containers_unmanaged{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "unmanaged", "refId": "C"},
        {"expr": "watchtower_containers_infrastructure{job=\"$job\", instance=~\"$instance\"}", "legendFormat": "infrastructure", "refId": "D"}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"lineInterpolation": "stepAfter", "lineWidth": 1, "fillOpacity": 10, "stacking": {"mode": "normal"}}}
      }
    },
    {
      "type": "row",
      "title": "Reliability & Security",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 20},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Poll duration (p50 / p95)",
      "description": "Wall-clock scan + update cycle duration. Sustained drift upwards is the first sign that a registry is slow or that one container's stop/start is hanging.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 21},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (le) (rate(watchtower_poll_duration_seconds_bucket{job=\"$job\", instance=~\"$instance\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(watchtower_poll_duration_seconds_bucket{job=\"$job\", instance=~\"$instance\"}[$__rate_interval])))", "legendFormat": "p95", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 1, "fillOpacity": 10}}}
    },
    {
      "type": "timeseries",
      "title": "Registry requests by outcome",
      "description": "watchtower_registry_requests_total — success / retried / error, summed across all registries. A sustained `retried` or `error` line means a flaky registry.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (outcome) (rate(watchtower_registry_requests_total{job=\"$job\", instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{outcome}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 1, "fillOpacity": 10}}}
    },
    {
      "type": "stat",
      "title": "HTTP API requests (non-2xx)",
      "description": "4xx / 5xx responses across /v1/update, /v1/metrics, /v1/audit over the last hour. A non-zero 401 burst on /v1/update suggests credential stuffing.",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 29},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (endpoint, status) (increase(watchtower_api_requests_total{job=\"$job\", instance=~\"$instance\", status!~\"2..\"}[1h]))", "legendFormat": "{{endpoint}} {{status}}", "refId": "A"}
      ],
      "options": {"colorMode": "background", "textMode": "value_and_name"},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}}
    },
    {
      "type": "stat",
      "title": "Docker API error rate (5m)",
      "description": "Errors returned by calls into the Docker engine API, broken down by operation. Persistent non-zero values usually mean socket permission issues or a daemon under load.",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 29},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (operation) (rate(watchtower_docker_api_errors_total{job=\"$job\", instance=~\"$instance\"}[5m]))", "legendFormat": "{{operation}}", "refId": "A"}
      ],
      "options": {"colorMode": "background", "textMode": "value_and_name"},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.01}]}}}
    },
    {
      "type": "stat",
      "title": "Bearer-token cache hit ratio",
      "description": "Hits / (hits + misses). High ratio means the in-memory cache added in v1.9 is effectively sparing the oauth endpoint.",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 29},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(increase(watchtower_auth_cache_hits_total{job=\"$job\", instance=~\"$instance\"}[1h])) / clamp_min(sum(increase(watchtower_auth_cache_hits_total{job=\"$job\", instance=~\"$instance\"}[1h])) + sum(increase(watchtower_auth_cache_misses_total{job=\"$job\", instance=~\"$instance\"}[1h])), 1)", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 0.5}, {"color": "green", "value": 0.8}]}}}
    },
    {
      "type": "stat",
      "title": "Image fallback events (24h)",
      "description": "Times GetContainer fell back to image-name inspection because the source image ID was GC'd — see upstream#1217. Occasional events are fine (--cleanup); sustained counts indicate external tooling is deleting images watchtower still needs.",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 29},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(increase(watchtower_image_fallback_total{job=\"$job\", instance=~\"$instance\"}[24h]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}]}}}
    },
    {
      "type": "row",
      "title": "Logs (requires Loki)",
      "description": "These two panels need a Loki datasource wired up. If you don't have Loki, pick \"Do not save\" when Grafana prompts for DS_LOKI at import time — the rest of the dashboard still works.",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 37},
      "collapsed": true,
      "panels": [
        {
          "type": "timeseries",
          "title": "Warn / error log rate",
          "description": "Rate of warn+error log lines per second, by level. Sudden spikes usually correlate with a registry flake or a broken release — pair with the Reliability & Security row above to isolate.",
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 38},
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "targets": [
            {"expr": "sum by (level) (count_over_time({container=\"watchtower\"} | logfmt | level=~\"(?i)warning|warn|error|fatal\" [$__interval]))", "legendFormat": "{{level}}", "refId": "A"}
          ],
          "fieldConfig": {"defaults": {"unit": "short"}},
          "options": {
            "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
            "tooltip": {"mode": "multi", "sort": "desc"}
          }
        },
        {
          "type": "logs",
          "title": "Warn / error logs",
          "description": "Live stream of warn+error log lines. Use the Grafana time range to scope to an incident window.",
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 38},
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "targets": [
            {"expr": "{container=\"watchtower\"} | logfmt | level=~\"(?i)warning|warn|error|fatal\"", "refId": "A"}
          ],
          "options": {
            "showTime": true,
            "showLabels": false,
            "showCommonLabels": false,
            "wrapLogMessage": true,
            "prettifyLogMessage": false,
            "enableLogDetails": true,
            "dedupStrategy": "none",
            "sortOrder": "Descending"
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["watchtower", "docker", "openserbia"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": {"selected": false, "text": "Loki", "value": "Loki"},
        "hide": 0,
        "description": "Optional. Only needed for the collapsed \"Logs\" row at the bottom. Pick \"Do not save\" at import time if you don't use Loki."
      },
      {
        "name": "job",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(watchtower_scans_total, job)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "sort": 1,
        "current": {"text": "watchtower", "value": "watchtower"}
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(watchtower_scans_total{job=\"$job\"}, instance)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Watchtower",
  "uid": "watchtower-openserbia",
  "version": 1,
  "weekStart": ""
}
