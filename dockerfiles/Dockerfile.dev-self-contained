#
# Builder
#

FROM golang:1.26-alpine@sha256:f23e8b227fb4493eabe03bede4d5a32d04092da71962f1fb79b5f7d1e6c2a17f AS builder

# Version string baked into the binary via ldflags. Pass it with
# --build-arg VERSION=$(git describe --tags); `task docker:build` does exactly
# that, so the build needs neither git nor the .git directory for versioning.
ARG VERSION=dev

# Pre download required modules to avoid redownloading at each build thanks to docker layer caching.
# Copying go.mod and go.sum ensure to invalid the layer/build cache if there is a change in module requirement
WORKDIR /watchtower
COPY go.mod .
COPY go.sum .
RUN go mod download

COPY . /watchtower

RUN \
  cd /watchtower && \
  \
  GO111MODULE=on CGO_ENABLED=0 GOOS=linux go build -a -ldflags "-extldflags '-static' -X github.com/openserbia/watchtower/internal/meta.Version=${VERSION}" . && \
  GO111MODULE=on go test ./... -v


#
# watchtower
#

# distroless static-debian13 bundles ca-certificates + tzdata and runs as root
# (needed for Docker socket access), so only the binary needs copying.
FROM gcr.io/distroless/static-debian13:latest@sha256:3592aa8171c77482f62bbc4164e6a2d141c6122554ace66e5cc910cadb961ff0

LABEL "com.centurylinklabs.watchtower"="true"

COPY --from=builder /watchtower/watchtower /watchtower

HEALTHCHECK CMD [ "/watchtower", "--health-check"]

ENTRYPOINT ["/watchtower"]
