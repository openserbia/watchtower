{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": {
    "github:openserbia/go-flake#go_1_26_3":            "",
    "github:openserbia/go-flake#golangci-lint_2_11_4": "",
    "github:openserbia/go-flake#gofumpt_0_10_0":       "",
    "github:openserbia/go-flake#govulncheck_1_3_0":    "",
    "gci": "latest",
    "go-task": "latest",
    "git": "latest",
    "docker": "latest",
    "goreleaser": "latest",
    "python3": "latest",
    "Trivy": "latest",
    "snyk": "latest",
    "cosign": "latest"
  },
  "env": {
    "GOROOT": "$DEVBOX_PROJECT_ROOT/.devbox/nix/profile/default/share/go"
  },
  "shell": {
    "init_hook": [
      ". $VENV_DIR/bin/activate",
      "pip install --upgrade pip -qq",
      "pip install -r requirements.txt -qq"
    ]
  }
}
